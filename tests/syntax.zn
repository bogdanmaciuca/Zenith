fn add(x: i32, y: i32) -> i32 {
    return x + y;
}

// Defines an alias for i32. Now Number and i32 can be used
// interchangeably
alias MyNumber = i32;

// Defines a new, distinct type, which needs an explicit cast to i32
type DistinctNumber = i32;

// All declarations are constants by default
my_number : i32 = 123; // Constant of type i32.
mut my_mutiable : u64; // mutable. Initialized by default with 0

my_array : i32[10]; // Size must be known at compile time
your_array : i32[10] = { 1, 4, 3, 5 };
his_array : i32[] = { 1, 2, 3, 4, 5 }; // Size if 5

// Compile time constant. Does not have a type;
// each expression will use it as whatever type it needs
comptime_constant :: 40;
string_constant :: "Hello Zenith!";

a : i32 = 69; // Explicit type
b := 420; // Inferring the type

ptr := &a; // Immutable pointer to a
ptr_1 := &a; // Immutable pointer to immutable a
ptr_unsafe : *mut i32 = &a; // Immutable pointer to mutable a

fn Max<T: Comparable>(a: &T, b: &T) -> T {
    if (a > b) { return a; }
    return b;
}

// TODO: Defining traits
namespace traits {
    trait Number { } // Empty trait, used as a tag

    // Tagging the integers and floats as Numbers
    impl i32: Number { }
    impl u32: Number { }
    // and so on...

    // Traits can also require functions and operators be defined for certain types
}

struct Point<T: traits::Number> {
    x : T;
    y : T;

    // Static methods
    fn New(x : T, y : T) -> Self {
        return Self{ x = x, y = y };
    }
    // Non-static methods take a Self object pointer/reference as the first parameter
    // If the self argument is a reference, this can be called in immutable Point instances
    fn SumSquared(self: &Self) -> T {
        return x * x + y * y;
    }
    // This has a pointer for self, so it can only be called from mutable Point instances
    fn Zero(self: *Self) -> T {
        self.x = 0;
        self.y = 0;
    }
}

p1 : Point<f32>;
p2 := Point<i32>{ 6, 9 };
p3 := Point<u8>::New(4, 20);

